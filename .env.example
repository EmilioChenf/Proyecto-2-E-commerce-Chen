PORT=3000
NODE_ENV=production
DATABASE_URL=
FRONTEND_URL=https://plushie-paradise-frontend.onrender.com
JWT_SECRET=
VITE_API_URL=https://plushie-paradise-api.onrender.com/api

# Variables locales para Docker/PostgreSQL
DB_HOST=db
DB_PORT=5432
DB_NAME=tienda_peluches
DB_USER=proy2
DB_PASSWORD=secret

POSTGRES_DB=tienda_peluches
POSTGRES_USER=proy2
POSTGRES_PASSWORD=secret
POSTGRES_PORT=5432

# Puertos locales de docker-compose
BACKEND_PORT=3000
FRONTEND_PORT=8080

JWT_EXPIRES_IN=7d
DB_CONNECTION_LIMIT=10

# Opcional. En Docker local, docker-compose usa defaults si se dejan vacias.
CORS_ORIGIN=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
VITE_GOOGLE_CLIENT_ID=
