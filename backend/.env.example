DB_PORT=5432
DB_NAME=tienda_peluches
DB_USER=proy2
DB_PASSWORD=secret
DB_CONNECTION_LIMIT=10

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
